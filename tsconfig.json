{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES7"],
    "allowJs": true,
    "removeComments": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "moduleResolution": "node",
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noImplicitAny": false,
    "noUnusedLocals": true,
    "sourceMap": true,
    "inlineSourceMap": false,
    "strict": true,
    "emitDeclarationOnly": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@prisloc/cli": ["./packages/cli"],
      "@prisloc/client": ["./packages/client"],
    }
  },
  "include": ["**/src/*.ts"],
  "exclude": ["**/build", "**/node_modules", "**/src/__tests__"]
}
