{
  "name": "prisloc",
  "version": "0.0.0",
  "description": "Build a local database for your applications with PrisLoc",
  "main": "build/index.js",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "turbo run test",
    "preinstall": "npx only-allow yarn",
    "commit": "yarn git-cz"
  },
  "engines": {
    "npm": ">=7.0.0",
    "node": ">=14.17.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sirlucasm/prisloc.git"
  },
  "author": "sirlucasm",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sirlucasm/prisloc/issues"
  },
  "homepage": "https://github.com/sirlucasm/prisloc#readme",
  "devDependencies": {
    "commitizen": "^4.2.6",
    "turbo": "^1.6.3"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "global": "^4.4.0",
    "gluegun": "^5.1.2"
  }
}
