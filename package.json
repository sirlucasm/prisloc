{
  "name": "prisloc",
  "version": "0.0.0",
  "private": true,
  "description": "Build a local database for your applications with PrisLoc",
  "main": "build/index.js",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "turbo run test",
    "preinstall": "npx only-allow yarn",
    "commit": "yarn git-cz",
    "eslint": "eslint",
    "lint": "eslint --fix --ext .ts ."
  },
  "engines": {
    "npm": ">=7.0.0",
    "node": ">=14.17.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sirlucasm/prisloc.git"
  },
  "author": "sirlucasm",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sirlucasm/prisloc/issues"
  },
  "homepage": "https://github.com/sirlucasm/prisloc#readme",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.48.0",
    "@typescript-eslint/parser": "^5.48.0",
    "commitizen": "^4.2.6",
    "eslint": "^8.31.0",
    "eslint-config-prettier": "^8.6.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-jest": "^27.2.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-simple-import-sort": "^8.0.0",
    "prettier": "^2.8.1",
    "turbo": "^1.6.3"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "global": "^4.4.0",
    "gluegun": "^5.1.2"
  },
  "workspaces": {
    "packages": ["packages/*", "examples"]
  }
}
